{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://kbtravelet-production.up.railway.app/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
